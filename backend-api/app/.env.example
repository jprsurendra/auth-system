# App
APP_ENV=development
APP_NAME=AuthService
DEBUG=true

# Security — change ALL of these in production
SECRET_KEY=change-this-to-a-64-char-random-string
OTP_HMAC_KEY=change-this-to-a-32-char-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
OTP_EXPIRE_SECONDS=600

# Cookie
COOKIE_SECURE=false
COOKIE_SAMESITE=strict

# CORS
ALLOWED_ORIGINS=["http://localhost:3000"]
ALLOWED_HOSTS=["localhost","127.0.0.1"]

# Database
DATABASE_URL=postgresql+asyncpg://authuser:devpassword@localhost:5432/authdb

# Redis
REDIS_URL=redis://localhost:6379/0

# Rate limits
RATE_LIMIT_OTP_MAX=5
RATE_LIMIT_OTP_WINDOW_SECONDS=900
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_WINDOW_SECONDS=600
RATE_LIMIT_REGISTER_MAX=3
RATE_LIMIT_REGISTER_WINDOW_SECONDS=3600

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_FROM_NUMBER=+1234567890

# SendGrid (Email)
SENDGRID_API_KEY=your_sendgrid_key
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=AuthService

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Sentry (optional)
SENTRY_DSN=



# Support team error notifications         ← NEW
SUPPORT_EMAIL=support@yourdomain.com
SUPPORT_EMAIL_NAME=Support Team
ERROR_NOTIFY_ENV=production
# Set to false in development to avoid
# flooding the support inbox during testing
ERROR_NOTIFICATIONS_ENABLED=true

# IP Geolocation (free tier — ipapi.co)    ← NEW
# No API key needed for up to 1000 req/day
# Upgrade to paid plan as traffic grows
IPAPI_URL=https://ipapi.co
